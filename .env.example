# Core app settings
PORT=5000
FLASK_DEBUG=1
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_EXPIRY_HOURS=24
ALLOW_GUEST_CHAT=0
CHAT_RATE_LIMIT=20 per minute
CHAT_DAILY_RATE_LIMIT=200 per day

# CORS: comma-separated origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5500,http://127.0.0.1:5500,null

# Database
# Local fallback (used when DATABASE_URL is not set): sqlite:///collegefindr.db
# Render Postgres: set DATABASE_URL in Render environment variables
DATABASE_URL=

# Optional: persistent rate-limit store, e.g. Redis URL
RATELIMIT_STORAGE_URI=memory://

# AI provider
OPENROUTER_API_KEY=
